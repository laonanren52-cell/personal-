{
  "name": "ai-priority-schedule-assistant",
  "version": "1.0.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "dev": "expo start --host lan",
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "build": "expo export --platform web && node scripts/postbuild-web.js",
    "build:web": "expo export --platform web && node scripts/postbuild-web.js",
    "preview": "serve -s dist -l tcp://0.0.0.0:3000",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@expo/vector-icons": "15.1.1",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/bottom-tabs": "7.18.2",
    "@react-navigation/native": "7.3.3",
    "expo": "56.0.12",
    "expo-blur": "56.0.3",
    "expo-constants": "56.0.18",
    "expo-image-picker": "56.0.18",
    "expo-linear-gradient": "56.0.4",
    "expo-notifications": "56.0.18",
    "expo-router": "56.2.11",
    "expo-status-bar": "56.0.4",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-web": "0.21.2"
  },
  "devDependencies": {
    "@types/react": "19.2.17",
    "serve": "14.2.5",
    "typescript": "6.0.3"
  }
}
